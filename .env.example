# game-review · 环境变量模板 (Phase 3 MVP)
#
# 用法: cp .env.example .env 然后填真值. .env 不要 commit (.gitignore 已排除).

# ==================== 后端 API ====================

# job 数据根目录 (默认 apps/api/data; 大磁盘推荐改到 /var/lib/game-review 或外接盘)
GAME_REVIEW_DATA_ROOT=apps/api/data

# game-review CLI 调用方式. 默认用当前 Python + module 形式.
# 如果要指定别的 venv 里的 CLI, 改成绝对路径:
#   GAME_REVIEW_CLI=/path/to/venv/bin/game-review
# GAME_REVIEW_CLI=python -m game_review.cli

# ==================== 前端 Web ====================

# 前端访问的 API 地址 (默认 localhost:8787). 部署时改成你的后端地址.
# 注意: NEXT_PUBLIC_ 前缀才能在浏览器端读到 (Next.js 约定).
NEXT_PUBLIC_API_URL=http://localhost:8787

# ==================== AI 评审 (Phase 3 待接入) ====================
# 当前 api/ai_stub.py 是占位实现, 接 LLM 后需要其中一个:

# Option A: OpenAI (推荐起步; gpt-4o-mini 便宜, gpt-4o 质量高)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Option B: Anthropic Claude (质量高, 贵一点)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Option C: DeepSeek (国内便宜)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-reasoner

# Option D: 自建 / 豆包 / Gemini / ... 自行追加

# ==================== Phase 4 预留 (不是现在) ====================
# DATABASE_URL=postgres://...     # Phase 4 换 Postgres
# REDIS_URL=redis://...            # Phase 4 队列
# S3_BUCKET=...                    # Phase 4 产物存 S3
# NEXTAUTH_SECRET=...              # Phase 4 登录
# STRIPE_SECRET_KEY=...            # Phase 4 收费
